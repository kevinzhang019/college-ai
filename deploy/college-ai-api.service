[Unit]
Description=College AI FastAPI Server
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/college-ai-v2
EnvironmentFile=/home/ec2-user/college-ai-v2/.env
ExecStart=/home/ec2-user/college-ai-v2/venv/bin/python -m uvicorn college_ai.api.app:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
